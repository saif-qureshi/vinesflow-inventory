{% if watermark %}<div class="watermark"><span>{{ watermark }}</span></div>{% endif %}
<div class="doc">
  <div class="head">
    <div>
      {% if show_logo %}<img class="logo" src="{{ company.logo_data_url }}" alt="">{% endif %}
      <div class="company-name">{{ company.name }}</div>
      <div class="company-lines">
        {% for line in company.lines %}<div>{{ line }}</div>{% endfor %}
      </div>
    </div>
    <div class="title-block">
      <div class="doc-title">{{ title }}</div>
      <div class="doc-no">{{ document_no }}</div>
      <div class="meta">
        {% for field in meta %}<div><span class="label">{{ field.label }}:</span> {{ field.value }}</div>{% endfor %}
      </div>
    </div>
  </div>

  {% if header_note %}<div class="header-note">{{ header_note }}</div>{% endif %}

  <div class="parties">
    {% for party in parties %}
    <div class="party">
      <div class="heading">{{ party.heading }}</div>
      <div class="name">{{ party.name }}</div>
      {% for line in party.lines %}<div class="line">{{ line }}</div>{% endfor %}
    </div>
    {% endfor %}
  </div>

  <table class="items">
    <thead>
      <tr>{% for col in columns %}<th class="{{ 'right' if col.align == 'right' else '' }}">{{ col.label }}</th>{% endfor %}</tr>
    </thead>
    <tbody>
      {% for row in rows %}
      <tr>{% for cell in row.cells %}<td class="{{ 'right tabular' if cell.align == 'right' else '' }}">{{ cell.value }}</td>{% endfor %}</tr>
      {% endfor %}
    </tbody>
  </table>

  <div class="foot">
    <div class="foot-left">
      {% if amount_in_words %}
      <div class="words">
        <div class="label">Amount in words</div>
        <div>{{ amount_in_words }}</div>
      </div>
      {% endif %}
      {% if notes %}<div class="block"><div class="label">Notes</div><div class="body">{{ notes }}</div></div>{% endif %}
      {% if terms %}<div class="block"><div class="label">Terms &amp; conditions</div><div class="body">{{ terms }}</div></div>{% endif %}
    </div>
    <div class="totals">
      {% for total in totals %}
      <div class="row {{ 'grand' if total.emphasize else '' }}">
        <span>{{ total.label }}</span><span class="tabular">{{ total.value }}</span>
      </div>
      {% endfor %}
    </div>
  </div>

  {% if stamp.image %}
  <div class="stamp">
    <div class="wrap">
      <img class="qr" src="{{ stamp.image }}" alt="">
      {% if stamp.overlay %}<img class="overlay" src="{{ stamp.overlay }}" alt="">{% endif %}
    </div>
    {% if stamp.caption %}<div class="caption">{{ stamp.caption }}</div>{% endif %}
  </div>
  {% endif %}

  {% if footer_contact %}
  <div class="contact">
    {% if footer_contact.phone %}<span>{{ footer_contact.phone }}</span>{% endif %}
    {% if footer_contact.email %}<span>{{ footer_contact.email }}</span>{% endif %}
    {% if footer_contact.website %}<span>{{ footer_contact.website }}</span>{% endif %}
    {% if footer_contact.address %}<span>{{ footer_contact.address }}</span>{% endif %}
  </div>
  {% endif %}
</div>
